#!/usr/bin/env bash

set -euo pipefail

store="${PASSWORD_STORE_DIR:-$HOME/.password-store}"

if [ ! -d "$store" ]; then
  echo "password store not found: $store" >&2
  exit 1
fi

entry="$(
  find "$store" -type f -name '*.gpg' -print0 |
    while IFS= read -r -d '' file; do
      rel="${file#"$store"/}"
      printf '%s\n' "${rel%.gpg}"
    done |
    sort |
    fzf --prompt='pass> ' --height=100% --layout=reverse || true
)"
[[ -z "$entry" ]] && exit 0

# Only get first line, never load full entry into memory
first_line="$(pass show "$entry" | head -n1)"

action="${TMUX_PASS_ACTION:-copy}"
target_pane="${TARGET_PANE:-}"

if [ -n "${TMUX:-}" ]; then
  # Pipe via stdin - password never appears in process args
  printf '%s' "$first_line" | tmux load-buffer -w -
else
  printf '%s' "$first_line" | cot
fi

if [ "$action" = "send" ] && [ -n "${TMUX:-}" ] && [ -n "$target_pane" ]; then
  # Use paste-buffer instead of send-keys - password not in process table
  printf '%s' "$first_line" | tmux load-buffer -w -
  tmux paste-buffer -t "$target_pane" -d  # -d deletes buffer after paste
  tmux send-keys -t "$target_pane" Enter
fi
