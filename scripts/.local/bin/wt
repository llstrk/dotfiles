#!/usr/bin/env bash
set -euo pipefail

# wt - Git Worktree Manager
# Creates a new worktree with a fresh branch from a source branch (default: dev),
# installs dependencies, and launches ocd.
#
# Usage: wt [branch-name]

if git rev-parse --is-bare-repository 2>/dev/null | grep -q true; then
  repo_root="$(realpath "$(git rev-parse --git-dir)")"
else
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || {
    echo "Error: not inside a git repository"
    exit 1
  }
fi

branch="${1:-}"
if [[ -z "$branch" ]]; then
  read -rp "Branch name: " branch
  if [[ -z "$branch" ]]; then
    echo "Error: no branch name provided"
    exit 1
  fi
fi

# Replace spaces with hyphens
branch="${branch// /-}"

read -rp "Source branch [dev]: " source_branch
source_branch="${source_branch:-dev}"

worktree_dir="${repo_root}/trees/${branch}"

echo "Fetching latest from origin..."
git fetch origin

if ! git rev-parse "origin/${source_branch}" &>/dev/null; then
  echo "Error: origin/${source_branch} not found. Check that '${source_branch}' exists on origin and that remote.origin.fetch is configured."
  exit 1
fi

echo "Creating worktree at ${worktree_dir}..."
if git show-ref --verify --quiet "refs/heads/$branch"; then
  echo "Error: branch '$branch' already exists."
  exit 1
fi

git worktree add -b "$branch" "$worktree_dir" "origin/${source_branch}"

cd "$worktree_dir"

echo "Installing dependencies..."
bun install

echo "Launching ocd..."
ocd
